{
  "name": "tssc-plugins",
  "version": "1.9",
  "backstageTarget": "1.45",
  "private": true,
  "engine": {
    "node": 22
  },
  "workspaces": {
    "packages": [
      "plugins/*"
    ]
  },
  "scripts": {
    "tsc": "turbo run tsc",
    "build": "turbo run build",
    "format": "prettier \"**/*.{js,ts,json}\" --write",
    "prettier": "prettier \"**/*.{js,ts,json}\" --check",
    "__comment_plugins": "TODO(v1.10): Revert the argocd exclusion filters below — remove the --filter='!./plugins/argocd' and --filter='!./plugins/argocd-backend' from each script. The community argocd plugins are not yet ready to ship in this release; redhat-argocd variants are used instead.",
    "plugins:prepare": "rimraf dist-plugin && turbo run clean-build --filter='./plugins/**' --filter='!./plugins/argocd' --filter='!./plugins/argocd-backend'",
    "plugins:build:frontend": "turbo run export-dynamic:frontend --filter='./plugins/**' --filter='!./plugins/argocd' --filter='!./plugins/argocd-backend'",
    "plugins:build:backend": "turbo run export-dynamic:backend --filter='./plugins/**' --filter='!./plugins/argocd' --filter='!./plugins/argocd-backend'",
    "plugins:build:backend:postinstall": "turbo run export-dynamic:backend:postinstall --filter='./plugins/**' --filter='!./plugins/argocd' --filter='!./plugins/argocd-backend'",
    "plugins:package": "turbo run package-dynamic --filter='./plugins/**' --filter='!./plugins/argocd' --filter='!./plugins/argocd-backend'",
    "build:image": "./scripts/build-and-push.sh",
    "build:utils": "tsc -p utils",
    "update:tssc-dynamic-plugins": "tsx utils/update-tssc-dynamic-plugin-tags.ts",
    "update:rhdh-dynamic-plugins": "tsx utils/update-rhdh-dynamic-plugin-tags.ts",
    "check:rhdh-dynamic-plugins": "tsx utils/update-rhdh-dynamic-plugin-tags.ts --check",
    "update:tekton-bundles": "./scripts/update-tekton-task-bundles.sh"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.8.1",
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "node-gyp": "^12.0.0",
    "prettier": "^3.5.3",
    "react": "16.13.1 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "rimraf": "6.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.4.4",
    "typescript": "5.8.2",
    "yaml": "^2.8.2"
  }
}
